{
  "name": "@botbye/nuxt",
  "version": "2.0.0",
  "description": "BotBye! integration for Nuxt",
  "type": "module",
  "exports": {
    "./server": {
      "types": "./src/server.d.ts",
      "import": "./src/server.js"
    },
    "./client": {
      "types": "./src/client.d.ts",
      "import": "./src/client.js"
    },
    "./module": {
      "types": "./src/module.d.ts",
      "import": "./src/module.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://botbye.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/botbye/botbye-nuxt"
  },
  "dependencies": {
    "@botbye/client": "^2.0.0",
    "@botbye/node-core": "^2.0.0"
  },
  "peerDependencies": {
    "nuxt": ">=3"
  }
}
